msgid "APSATTV Favorites List have been removed"
msgstr "APSATTV дуртай жагсаалт хасагдсан"

msgid "Back"
msgstr "Буцах"

msgid "Congrats! You already have the latest version..."
msgstr "Баяр хүргэе! Танд хамгийн сүүлийн хувилбар байгаа..."

msgid "Do you want to install update ( %s ) now?"
msgstr "Та одоо шинэчлэлтийг ( %s ) суулгахыг хүсэж байна уу?"

msgid "Download Error"
msgstr "Татаж авах алдаа"

msgid "Error checking version: %s"
msgstr "Хувилбарыг шалгахад алдаа гарлаа: %s"

msgid "Exit"
msgstr "Гарах"

msgid "Export"
msgstr "Экспорт"

msgid "Filter this category..."
msgstr "Энэ ангиллыг шүүх..."

msgid "Please install SubSupport Plugins"
msgstr "SubSupport Plugins суулгана уу"

msgid "Remove Bouquet"
msgstr "Bouquet арилгах"

msgid "Remove all APSATTV Favorite Bouquet?"
msgstr "Бүх APSATTV-ийн дуртай баглааг устгах уу?"

msgid "Search"
msgstr "Хайх"

msgid "Update"
msgstr "Шинэчлэх"

msgid "Update Aborted!"
msgstr "Шинэчлэлтийг зогсоосон!"
