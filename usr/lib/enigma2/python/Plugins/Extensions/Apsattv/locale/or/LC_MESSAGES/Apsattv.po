msgid "APSATTV Favorites List have been removed"
msgstr "APSATTV ପ୍ରିୟ ତାଲିକା ଅପସାରିତ ହୋଇଛି |"

msgid "Back"
msgstr "ପଛକୁ"

msgid "Congrats! You already have the latest version..."
msgstr "ଅଭିନନ୍ଦନ! ଆପଣଙ୍କ ପାଖରେ ସର୍ବଶେଷ ସଂସ୍କରଣ ଅଛି ..."

msgid "Do you want to install update ( %s ) now?"
msgstr "ଆପଣ ବର୍ତ୍ତମାନ ଅଦ୍ୟତନ (% s) ସଂସ୍ଥାପନ କରିବାକୁ ଚାହୁଁଛନ୍ତି କି?"

msgid "Download Error"
msgstr "ତ୍ରୁଟି ଡାଉନଲୋଡ୍ କରନ୍ତୁ |"

msgid "Error checking version: %s"
msgstr "ସଂସ୍କରଣ ଯାଞ୍ଚରେ ତ୍ରୁଟି:% s"

msgid "Exit"
msgstr "ପ୍ରସ୍ଥାନ"

msgid "Export"
msgstr "ରପ୍ତାନି କରନ୍ତୁ |"

msgid "Filter this category..."
msgstr "ଏହି ବର୍ଗ ଫିଲ୍ଟର୍ କରନ୍ତୁ ..."

msgid "Please install SubSupport Plugins"
msgstr "ଦୟାକରି ସବ୍ ସପୋର୍ଟ ପ୍ଲଗଇନ୍ ସଂସ୍ଥାପନ କରନ୍ତୁ |"

msgid "Remove Bouquet"
msgstr "ପୁଷ୍ପ ହଟାନ୍ତୁ |"

msgid "Remove all APSATTV Favorite Bouquet?"
msgstr "ସମସ୍ତ APSATTV ପ୍ରିୟ ପୁଷ୍ପ ହଟାନ୍ତୁ?"

msgid "Search"
msgstr "ସନ୍ଧାନ କର |"

msgid "Update"
msgstr "ଅଦ୍ୟତନ କରନ୍ତୁ |"

msgid "Update Aborted!"
msgstr "ପରିତ୍ୟାଗ କରାଯାଇଥିବା ଅଦ୍ୟତନ!"
