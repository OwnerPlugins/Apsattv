msgid "APSATTV Favorites List have been removed"
msgstr "APSATTV Sevimlilar roʻyxati olib tashlandi"

msgid "Back"
msgstr "Orqaga"

msgid "Congrats! You already have the latest version..."
msgstr "Tabriklaymiz! Sizda allaqachon oxirgi versiya mavjud..."

msgid "Do you want to install update ( %s ) now?"
msgstr "Yangilanishni ( %s ) hozir oʻrnatmoqchimisiz?"

msgid "Download Error"
msgstr "Yuklab olish xatosi"

msgid "Error checking version: %s"
msgstr "Versiyani tekshirishda xatolik yuz berdi: %s"

msgid "Exit"
msgstr "Chiqish"

msgid "Export"
msgstr "Eksport"

msgid "Filter this category..."
msgstr "Ushbu turkumni filtrlash..."

msgid "Please install SubSupport Plugins"
msgstr "Iltimos, SubSupport plaginlarini o'rnating"

msgid "Remove Bouquet"
msgstr "Buketni olib tashlang"

msgid "Remove all APSATTV Favorite Bouquet?"
msgstr "Barcha APSATTV sevimli guldastasi olib tashlansinmi?"

msgid "Search"
msgstr "Qidiruv"

msgid "Update"
msgstr "Yangilash"

msgid "Update Aborted!"
msgstr "Yangilash bekor qilindi!"
