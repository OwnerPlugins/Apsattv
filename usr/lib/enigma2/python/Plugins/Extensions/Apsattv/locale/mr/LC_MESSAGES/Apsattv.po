msgid "APSATTV Favorites List have been removed"
msgstr "APSATTV पसंतीची यादी काढून टाकली आहे"

msgid "Back"
msgstr "मागे"

msgid "Congrats! You already have the latest version..."
msgstr "अभिनंदन! तुमच्याकडे आधीपासूनच नवीनतम आवृत्ती आहे..."

msgid "Do you want to install update ( %s ) now?"
msgstr "तुम्हाला आता अपडेट (%s) स्थापित करायचे आहे का?"

msgid "Download Error"
msgstr "डाउनलोड त्रुटी"

msgid "Error checking version: %s"
msgstr "आवृत्ती तपासताना त्रुटी: %s"

msgid "Exit"
msgstr "बाहेर पडा"

msgid "Export"
msgstr "निर्यात करा"

msgid "Filter this category..."
msgstr "ही श्रेणी फिल्टर करा..."

msgid "Please install SubSupport Plugins"
msgstr "कृपया सबसपोर्ट प्लगइन स्थापित करा"

msgid "Remove Bouquet"
msgstr "पुष्पगुच्छ काढा"

msgid "Remove all APSATTV Favorite Bouquet?"
msgstr "सर्व APSATTV आवडते पुष्पगुच्छ काढायचे?"

msgid "Search"
msgstr "शोधा"

msgid "Update"
msgstr "अपडेट करा"

msgid "Update Aborted!"
msgstr "अद्यतन रद्द केले!"
