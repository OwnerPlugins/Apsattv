msgstr "ออก"

msgid "Export"
msgstr "ส่งออก"

msgid "Filter this category..."
msgstr "กรองหมวดหมู่นี้..."

msgid "Please install SubSupport Plugins"
msgstr "กรุณาติดตั้งปลั๊กอิน SubSupport"

msgid "Remove Bouquet"
msgstr "ลบช่อดอกไม้"

