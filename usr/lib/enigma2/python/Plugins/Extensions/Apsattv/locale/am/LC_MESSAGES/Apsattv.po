msgid "APSATTV Favorites List have been removed"
msgstr "APSATTV ተወዳጆች ዝርዝር ተወግዷል"

msgid "Back"
msgstr "ተመለስ"

msgid "Congrats! You already have the latest version..."
msgstr "እንኳን ደስ ያለህ! ቀድሞውንም የቅርብ ጊዜ ስሪት አለህ..."

msgid "Do you want to install update ( %s ) now?"
msgstr "ማሻሻያ (%s) አሁን መጫን ይፈልጋሉ?"

msgid "Download Error"
msgstr "የማውረድ ስህተት"

msgid "Error checking version: %s"
msgstr "ስሪቱን በመፈተሽ ላይ ስህተት፡%s"

msgid "Exit"
msgstr "ውጣ"

msgid "Export"
msgstr "ወደ ውጪ ላክ"

msgid "Filter this category..."
msgstr "ይህን ምድብ አጣራ..."

msgid "Please install SubSupport Plugins"
msgstr "እባክዎን የድጋፍ ፕለጊኖችን ይጫኑ"

msgid "Remove Bouquet"
msgstr "Bouquet አስወግድ"

msgid "Remove all APSATTV Favorite Bouquet?"
msgstr "ሁሉም APSATTV ተወዳጅ ቡኬት ይወገድ?"

msgid "Search"
msgstr "ፈልግ"

msgid "Update"
msgstr "አዘምን"

msgid "Update Aborted!"
msgstr "ዝማኔ ተቋርጧል!"
