msgid "APSATTV Favorites List have been removed"
msgstr "Chaidh Liosta Roghainnean APSATTV a thoirt air falbh"

msgid "Back"
msgstr "Air ais"

msgid "Congrats! You already have the latest version..."
msgstr "Mealaibh ur naidheachd! Tha an tionndadh as ùire agad mu thràth ..."

msgid "Do you want to install update ( %s ) now?"
msgstr "A bheil thu airson ùrachadh ( %s ) a stàladh an-dràsta?"

msgid "Download Error"
msgstr "Luchdaich sìos mearachd"

msgid "Error checking version: %s"
msgstr "Thachair mearachd le sgrùdadh an tionndaidh: %s"

msgid "Exit"
msgstr "Ar-a-mach"

msgid "Export"
msgstr "Às-mhalairt"

msgid "Filter this category..."
msgstr "Criathraich an roinn seo..."

msgid "Please install SubSupport Plugins"
msgstr "Feuch an stàlaich thu plugan SubSupport"

msgid "Remove Bouquet"
msgstr "Thoir air falbh Bouquet"

msgid "Remove all APSATTV Favorite Bouquet?"
msgstr "Thoir air falbh a h-uile Bouquet as fheàrr le APSATV?"

msgid "Search"
msgstr "Rannsaich"

msgid "Update"
msgstr "Ùraich"

msgid "Update Aborted!"
msgstr "Ùrachadh air a sguireadh!"
