msgid "Please install SubSupport Plugins"
msgstr "SubSupport Plugins ကို ထည့်သွင်းပါ။"

msgid "Remove Bouquet"
msgstr "ပန်းစည်းကို ဖယ်ရှားပါ။"

msgid "Remove all APSATTV Favorite Bouquet?"
msgstr "APSATTV Favourite Bouquet အားလုံးကို ဖယ်ရှားမလား။"

msgid "Search"
msgstr "ရှာရန်"

msgid "Update"
msgstr "အပ်ဒိတ်"

msgid "Update Aborted!"
msgstr "အပ်ဒိတ်ကို ဖျက်သိမ်းလိုက်ပါပြီ။"
