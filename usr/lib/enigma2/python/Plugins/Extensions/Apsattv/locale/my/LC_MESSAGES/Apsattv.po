msgid "APSATTV Favorites List have been removed"
msgstr "APSATTV အကြိုက်ဆုံးစာရင်းကို ဖယ်ရှားလိုက်ပါပြီ။"

msgid "Back"
msgstr "ကျော"

msgid "Congrats! You already have the latest version..."
msgstr "ဂုဏ်ပြုပါသည်။ သင့်တွင် နောက်ဆုံးထွက်ဗားရှင်းရှိနေပြီဖြစ်သည်။"

msgid "Do you want to install update ( %s ) now?"
msgstr "အပ်ဒိတ် (%s) ကို ယခု ထည့်သွင်းလိုပါသလား။"

msgid "Download Error"
msgstr "ဒေါင်းလုဒ်အမှား"

msgid "Error checking version: %s"
msgstr "ဗားရှင်းစစ်ဆေးရာတွင် အမှားအယွင်းရှိနေသည်- %s"

msgid "Exit"
msgstr "ထွက်ပေါက်"

