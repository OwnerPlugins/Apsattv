msgid "APSATTV Favorites List have been removed"
msgstr "APSATTV पसंदीदा सूची हटा दी गई है"

msgid "Back"
msgstr "पीछे"

msgid "Congrats! You already have the latest version..."
msgstr "बधाई! आपके पास पहले से ही नवीनतम संस्करण है..."

msgid "Do you want to install update ( %s ) now?"
msgstr "क्या आप अभी अपडेट ( %s ) इंस्टॉल करना चाहते हैं?"

msgid "Download Error"
msgstr "डाउनलोड त्रुटि"

msgid "Error checking version: %s"
msgstr "संस्करण जाँचने में त्रुटि: %s"

msgid "Exit"
msgstr "बाहर निकलना"

msgid "Export"
msgstr "निर्यात"

msgid "Filter this category..."
msgstr "इस श्रेणी को फ़िल्टर करें..."

msgid "Please install SubSupport Plugins"
msgstr "कृपया सबसपोर्ट प्लगइन्स इंस्टॉल करें"

msgid "Remove Bouquet"
msgstr "गुलदस्ता हटाओ"

msgid "Remove all APSATTV Favorite Bouquet?"
msgstr "सभी APSATTV पसंदीदा गुलदस्ता निकालें?"

msgid "Search"
msgstr "खोज"

msgid "Update"
msgstr "अद्यतन"

msgid "Update Aborted!"
msgstr "अद्यतन निरस्त किया गया!"
