msgid "APSATTV Favorites List have been removed"
msgstr "APSATTV मनपर्ने सूची हटाइयो"

msgid "Back"
msgstr "पछाडि"

msgid "Congrats! You already have the latest version..."
msgstr "बधाई छ! तपाईंसँग पहिले नै नवीनतम संस्करण छ..."

msgid "Do you want to install update ( %s ) now?"
msgstr "के तपाई अहिले अपडेट (%s) स्थापना गर्न चाहनुहुन्छ?"

msgid "Download Error"
msgstr "डाउनलोड त्रुटि"

msgid "Error checking version: %s"
msgstr "संस्करण जाँच गर्दा त्रुटि: %s"

msgid "Exit"
msgstr "बाहिर निस्कनुहोस्"

msgid "Export"
msgstr "निर्यात गर्नुहोस्"

msgid "Filter this category..."
msgstr "यो श्रेणी फिल्टर गर्नुहोस्..."

msgid "Please install SubSupport Plugins"
msgstr "कृपया सबसपोर्ट प्लगइनहरू स्थापना गर्नुहोस्"

msgid "Remove Bouquet"
msgstr "गुलदस्ता हटाउनुहोस्"

msgid "Remove all APSATTV Favorite Bouquet?"
msgstr "सबै APSATTV मनपर्ने गुलदस्ता हटाउने हो?"

msgid "Search"
msgstr "खोज्नुहोस्"

msgid "Update"
msgstr "अपडेट गर्नुहोस्"

msgid "Update Aborted!"
msgstr "अपडेट रद्द गरियो!"
