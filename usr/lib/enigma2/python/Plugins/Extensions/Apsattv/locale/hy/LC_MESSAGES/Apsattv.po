msgid "APSATTV Favorites List have been removed"
msgstr "APSATTV-ի ընտրյալների ցանկը հեռացվել է"

msgid "Back"
msgstr "Ետ"

msgid "Congrats! You already have the latest version..."
msgstr "Շնորհավորում եմ Դուք արդեն ունեք վերջին տարբերակը..."

msgid "Do you want to install update ( %s ) now?"
msgstr "Ցանկանու՞մ եք տեղադրել թարմացումը ( %s ) հիմա:"

