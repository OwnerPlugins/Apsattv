msgstr "Ներբեռնման սխալ"

msgid "Error checking version: %s"
msgstr "Չհաջողվեց ստուգել տարբերակը՝ %s"

msgid "Exit"
msgstr "Ելք"

msgid "Export"
msgstr "Արտահանում"

msgid "Filter this category..."
msgstr "Զտել այս կատեգորիան..."

msgid "Please install SubSupport Plugins"
msgstr "Խնդրում ենք տեղադրել SubSupport Plugins"

msgid "Remove Bouquet"
msgstr "Հեռացրեք ծաղկեփունջը"

