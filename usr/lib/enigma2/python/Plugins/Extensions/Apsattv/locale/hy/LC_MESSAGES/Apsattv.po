msgstr "Հեռացնե՞լ բոլոր APSATTV-ի սիրելի ծաղկեփունջը:"

msgid "Search"
msgstr "Որոնում"

msgid "Update"
msgstr "Թարմացնել"

msgid "Update Aborted!"
msgstr "Թարմացումը ընդհատվեց:"
