msgid "APSATTV Favorites List have been removed"
msgstr "APSATTV ਮਨਪਸੰਦ ਸੂਚੀ ਹਟਾ ਦਿੱਤੀ ਗਈ ਹੈ"

msgid "Back"
msgstr "ਵਾਪਸ"

msgid "Congrats! You already have the latest version..."
msgstr "ਵਧਾਈਆਂ! ਤੁਹਾਡੇ ਕੋਲ ਪਹਿਲਾਂ ਹੀ ਨਵੀਨਤਮ ਸੰਸਕਰਣ ਹੈ..."

msgid "Do you want to install update ( %s ) now?"
msgstr "ਕੀ ਤੁਸੀਂ ਹੁਣੇ ਅੱਪਡੇਟ (%s) ਨੂੰ ਸਥਾਪਿਤ ਕਰਨਾ ਚਾਹੁੰਦੇ ਹੋ?"

msgid "Download Error"
msgstr "ਡਾਊਨਲੋਡ ਤਰੁੱਟੀ"

msgid "Error checking version: %s"
msgstr "ਸੰਸਕਰਣ ਦੀ ਜਾਂਚ ਕਰਨ ਵਿੱਚ ਤਰੁੱਟੀ: %s"

msgid "Exit"
msgstr "ਨਿਕਾਸ"

msgid "Export"
msgstr "ਨਿਰਯਾਤ"

msgid "Filter this category..."
msgstr "ਇਸ ਸ਼੍ਰੇਣੀ ਨੂੰ ਫਿਲਟਰ ਕਰੋ..."

msgid "Please install SubSupport Plugins"
msgstr "ਕਿਰਪਾ ਕਰਕੇ ਸਬਸਪੋਰਟ ਪਲੱਗਇਨ ਸਥਾਪਿਤ ਕਰੋ"

msgid "Remove Bouquet"
msgstr "ਗੁਲਦਸਤਾ ਹਟਾਓ"

msgid "Remove all APSATTV Favorite Bouquet?"
msgstr "ਸਾਰੇ APSATTV ਮਨਪਸੰਦ ਗੁਲਦਸਤੇ ਨੂੰ ਹਟਾਉਣਾ ਹੈ?"

msgid "Search"
msgstr "ਖੋਜ"

msgid "Update"
msgstr "ਅੱਪਡੇਟ ਕਰੋ"

msgid "Update Aborted!"
msgstr "ਅੱਪਡੇਟ ਅਧੂਰਾ ਛੱਡਿਆ ਗਿਆ!"
